{
  "Name": "aaggarwal1-tailwag-dev-daily-report",
  "GroupName": "aaggarwal1-tailwag-dev",
  "Description": "Send one daily Tailwag report generation job to SQS.",
  "ScheduleExpression": "cron(0 10 * * ? *)",
  "ScheduleExpressionTimezone": "UTC",
  "State": "DISABLED",
  "FlexibleTimeWindow": {
    "Mode": "OFF"
  },
  "Target": {
    "Arn": "arn:aws:sqs:us-east-2:<account-id>:aaggarwal1-tailwag-dev-report-jobs",
    "RoleArn": "arn:aws:iam::<account-id>:role/aaggarwal1-tailwag-dev-scheduler-role",
    "RetryPolicy": {
      "MaximumEventAgeInSeconds": 900,
      "MaximumRetryAttempts": 2
    },
    "DeadLetterConfig": {
      "Arn": "arn:aws:sqs:us-east-2:<account-id>:aaggarwal1-tailwag-dev-report-jobs-dlq"
    },
    "Input": "{\"job_type\":\"report_generate\",\"job_id\":\"daily-report-<aws.scheduler.execution-id>\",\"reports\":[\"memory_items\",\"person_timeline\",\"followup_validity\"],\"output_prefix\":\"daily/\"}"
  }
}
