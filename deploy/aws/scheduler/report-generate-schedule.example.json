{
  "Name": "tailwag-memory-dev-daily-report",
  "Description": "Send one daily Tailwag report generation job to SQS.",
  "ScheduleExpression": "cron(0 10 * * ? *)",
  "ScheduleExpressionTimezone": "UTC",
  "FlexibleTimeWindow": {
    "Mode": "OFF"
  },
  "Target": {
    "Arn": "arn:aws:sqs:<region>:<account-id>:tailwag-memory-<environment>-report-jobs",
    "RoleArn": "arn:aws:iam::<account-id>:role/tailwag-memory-<environment>-scheduler-role",
    "Input": "{\"job_type\":\"report_generate\",\"job_id\":\"daily-report-<scheduled-time>\",\"reports\":[\"memory_items\",\"person_timeline\",\"followup_validity\"],\"output_prefix\":\"daily/\"}"
  }
}
