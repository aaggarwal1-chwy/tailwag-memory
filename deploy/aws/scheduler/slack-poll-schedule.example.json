{
  "Name": "tailwag-memory-dev-slack-poll-C0123456789",
  "Description": "Send one recurring Tailwag Slack poll job to SQS.",
  "ScheduleExpression": "rate(5 minutes)",
  "FlexibleTimeWindow": {
    "Mode": "OFF"
  },
  "Target": {
    "Arn": "arn:aws:sqs:<region>:<account-id>:tailwag-memory-<environment>-poll-jobs",
    "RoleArn": "arn:aws:iam::<account-id>:role/tailwag-memory-<environment>-scheduler-role",
    "Input": "{\"job_type\":\"slack_poll\",\"job_id\":\"slack-poll-C0123456789-<scheduled-time>\",\"channel\":\"C0123456789\",\"history_limit\":200,\"reply_limit\":200,\"extract_memory\":false}"
  }
}
