{
  "Name": "aaggarwal1-tailwag-dev-relay-maintenance",
  "GroupName": "aaggarwal1-tailwag-dev",
  "Description": "Expire relay messages and recover abandoned claims through the existing memory worker.",
  "ScheduleExpression": "rate(5 minutes)",
  "State": "DISABLED",
  "FlexibleTimeWindow": {
    "Mode": "OFF"
  },
  "Target": {
    "Arn": "arn:aws:sqs:us-east-2:<account-id>:aaggarwal1-tailwag-dev-memory-jobs",
    "RoleArn": "arn:aws:iam::<account-id>:role/aaggarwal1-tailwag-dev-scheduler-role",
    "RetryPolicy": {
      "MaximumEventAgeInSeconds": 900,
      "MaximumRetryAttempts": 2
    },
    "DeadLetterConfig": {
      "Arn": "arn:aws:sqs:us-east-2:<account-id>:aaggarwal1-tailwag-dev-memory-jobs-dlq"
    },
    "Input": "{\"job_type\":\"relay_maintenance\",\"job_id\":\"relay-maintenance-<aws.scheduler.execution-id>\",\"claim_timeout_seconds\":120}"
  }
}
