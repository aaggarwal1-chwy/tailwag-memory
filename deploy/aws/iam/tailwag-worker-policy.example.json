{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ProcessTailwagQueues",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:ChangeMessageVisibility",
        "sqs:GetQueueAttributes",
        "sqs:GetQueueUrl",
        "sqs:SendMessage"
      ],
      "Resource": [
        "arn:aws:sqs:<region>:<account-id>:tailwag-memory-<environment>-poll-jobs",
        "arn:aws:sqs:<region>:<account-id>:tailwag-memory-<environment>-memory-jobs",
        "arn:aws:sqs:<region>:<account-id>:tailwag-memory-<environment>-report-jobs"
      ]
    },
    {
      "Sid": "UseTailwagWorkerTables",
      "Effect": "Allow",
      "Action": [
        "dynamodb:DescribeTable",
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:<region>:<account-id>:table/tailwag-memory-<environment>-slack-poll-state",
        "arn:aws:dynamodb:<region>:<account-id>:table/tailwag-memory-<environment>-job-idempotency"
      ]
    },
    {
      "Sid": "WriteTailwagReports",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::<tailwag-reports-bucket>",
        "arn:aws:s3:::<tailwag-reports-bucket>/*"
      ]
    }
  ]
}
