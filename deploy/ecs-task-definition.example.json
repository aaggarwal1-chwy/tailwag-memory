{
  "family": "aaggarwal1-tailwag-api-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/aaggarwal1-tailwag-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/aaggarwal1-tailwag-api-task-role",
  "containerDefinitions": [
    {
      "name": "tailwag-memory-api",
      "image": "<account-id>.dkr.ecr.us-east-2.amazonaws.com/aaggarwal1-tailwag-dev-api:<tag>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "TAILWAG_API_PORT", "value": "8000"},
        {"name": "TAILWAG_MEMORY_JOBS_QUEUE_URL", "value": "https://sqs.us-east-2.amazonaws.com/<account-id>/aaggarwal1-tailwag-dev-memory-jobs"},
        {"name": "TAILWAG_API_DOCS_ENABLED", "value": "false"},
        {"name": "TAILWAG_EMBEDDING_MODEL", "value": "text-embedding-3-small"},
        {"name": "TAILWAG_EMBEDDING_DIMENSION", "value": "64"},
        {"name": "TAILWAG_FACE_EMBEDDING_DIMENSION", "value": "512"},
        {"name": "TAILWAG_VOICE_EMBEDDING_DIMENSION", "value": "192"},
        {"name": "TAILWAG_FACE_EMBEDDING_MODEL", "value": "facenet"},
        {"name": "TAILWAG_VOICE_EMBEDDING_MODEL", "value": "speechbrain_ecapa"},
        {"name": "TAILWAG_SYNTHESIS_MODEL", "value": "gpt-5.5"},
        {"name": "TAILWAG_RELAY_POLICY_MODEL", "value": "gpt-5.5"},
        {"name": "TAILWAG_RELAY_DEFAULT_EXPIRY_DAYS", "value": "30"},
        {"name": "TAILWAG_RELAY_MAX_BODY_CHARACTERS", "value": "500"},
        {"name": "TAILWAG_RELAY_MAX_PENDING_PER_PAIR", "value": "3"},
        {"name": "TAILWAG_RELAY_MAX_SENDS_PER_SENDER_PER_DAY", "value": "5"}
      ],
      "secrets": [
        {"name": "NEO4J_URI", "valueFrom": "<complete-neo4j-uri-secret-arn-from-describe-secret>"},
        {"name": "NEO4J_USER", "valueFrom": "<complete-neo4j-user-secret-arn-from-describe-secret>"},
        {"name": "NEO4J_PASSWORD", "valueFrom": "<complete-neo4j-password-secret-arn-from-describe-secret>"},
        {"name": "OPENAI_API_KEY", "valueFrom": "<complete-openai-api-key-secret-arn-from-describe-secret>"},
        {"name": "TAILWAG_API_BEARER_TOKEN", "valueFrom": "<complete-api-bearer-token-secret-arn-from-describe-secret>"},
        {"name": "TAILWAG_ROBOT_API_TOKENS_JSON", "valueFrom": "<complete-robot-api-tokens-json-secret-arn-from-describe-secret>"}
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health', timeout=3).read()\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/aaggarwal1-tailwag-api",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
